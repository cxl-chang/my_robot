<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org.wiki/xacro">

    <xacro:property name="arm_base_length" value="0.4" />
    <xacro:property name="arm_base_width" value="0.4" />
    <xacro:property name="arm_base_height" value="0.1" />

    <xacro:property name="shoulder_length" value="0.5" />
    <xacro:property name="shoulder_radius" value="0.1" />

    <xacro:property name="arm_length" value="0.6" />
    <xacro:property name="arm_radius" value="0.05" />

    <xacro:property name="elbow_length" value="0.1" />
    <xacro:property name="elbow_radius" value="0.05" />

    <xacro:property name="forearm_length" value="0.5" />
    <xacro:property name="forearm_radius" value="0.05" />

    <xacro:property name="wrist_length" value="0.1" />
    <xacro:property name="wrist_width" value="0.1" />
    <xacro:property name="wrist_height" value="0.05" />

    <xacro:property name="hand_length" value="0.1" />
    <xacro:property name="hand_width" value="0.1" />
    <xacro:property name="hand_height" value="0.02" />

    <link name="arm_base_link">
        <visual>
            <origin xyz="0.0 0.0 ${arm_base_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}"/>
            </geometry>
            <material name="orange" />
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${arm_base_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}"/>
            </geometry>
        </collision>
        
        <xacro:box_inertia m="3.0" x="${arm_base_length}" y="${arm_base_width}" z="${arm_base_height}" 
                           o_xyz="0.0 0.0 ${arm_base_height/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="shoulder_link">
        <visual>
            <origin xyz="0.0 0.0 ${shoulder_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${shoulder_radius}" length="${shoulder_length}"/>
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${shoulder_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${shoulder_radius}" length="${shoulder_length}"/>
            </geometry>
        </collision>

        <xacro:cylinder_inertia m="1.5" r="${shoulder_radius}" h="${shoulder_length}"
                                o_xyz="0.0 0.0 ${shoulder_length/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="arm_link">
        <visual>
            <origin xyz="0.0 0.0 ${arm_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${arm_radius}" length="${arm_length}"/>
            </geometry>
            <material name="grey" />
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${arm_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${arm_radius}" length="${arm_length}"/>
            </geometry>
        </collision>

        <xacro:cylinder_inertia m="1.0" r="${arm_radius}" h="${arm_length}"
                                o_xyz="0.0 0.0 ${arm_length/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="elbow_link">
        <visual>
            <origin xyz="0.0 0.0 ${elbow_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${elbow_radius}" length="${elbow_length}"/>
            </geometry>
            <material name="blue" />
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${elbow_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${elbow_radius}" length="${elbow_length}"/>
            </geometry>
        </collision>

        <xacro:cylinder_inertia m="0.1" r="${elbow_radius}" h="${elbow_length}"
                                o_xyz="0.0 0.0 ${elbow_length/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="forearm_link">
        <visual>
            <origin xyz="0.0 0.0 ${forearm_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
            </geometry>
            <material name="grey" />
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${forearm_length/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
            </geometry>
        </collision>

        <xacro:cylinder_inertia m="0.5" r="${forearm_radius}" h="${forearm_length}"
                                o_xyz="0.0 0.0 ${forearm_length/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="wrist_link">
        <visual>
            <origin xyz="0.0 0.0 ${wrist_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${wrist_length} ${wrist_width} ${wrist_height}"/>
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${wrist_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${wrist_length} ${wrist_width} ${wrist_height}"/>
            </geometry>
        </collision>

        <xacro:box_inertia m="0.1" x="${wrist_length}" y="${wrist_width}" z="${wrist_height}"
                           o_xyz="0.0 0.0 ${wrist_height/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="hand_link">
        <visual>
            <origin xyz="0.0 0.0 ${hand_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${hand_length} ${hand_width} ${hand_height}"/>
            </geometry>
            <material name="grey" />
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${hand_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${hand_length} ${hand_width} ${hand_height}"/>
            </geometry>
        </collision>

        <xacro:box_inertia m="0.1" x="${hand_length}" y="${hand_width}" z="${hand_height}"
                           o_xyz="0.0 0.0 ${hand_height/2.0}" o_rpy="0 0 0" />
    </link>

    <link name="tool_link">
    </link>

    <joint name="base_arm_joint" type="fixed">
        <origin xyz="0.0 0.0 ${base_height}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="arm_base_link"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <joint name="joint1" type="revolute">
        <origin xyz="0.0 0.0 ${arm_base_height}" rpy="0.0 0.0 0.0"/>
        <parent link="arm_base_link"/>
        <child link="shoulder_link"/>
        <axis xyz="0.0 0.0 1"/>
        <limit lower="-3.14" upper="3.14" effort="1000.0" velocity="1.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <joint name="joint2" type="revolute">
        <origin xyz="0.0 0.0 ${shoulder_length}" rpy="0.0 0.5 0.0"/>
        <parent link="shoulder_link"/>
        <child link="arm_link"/>
        <axis xyz="0.0 1.0 0.0"/>
        <limit lower="-2.5" upper="0.6" effort="1000.0" velocity="1.0"/>
        <dynamics damping="10" friction="10"/>
    </joint>

    <joint name="joint3" type="revolute">
        <origin xyz="0.0 0.0 ${arm_length}" rpy="0.0 0.0 0.0"/>
        <parent link="arm_link"/>
        <child link="elbow_link"/>
        <axis xyz="0.0 1.0 0.0"/>
        <limit lower="-2.5" upper="0.6" effort="1000.0" velocity="1.0"/>
        <dynamics damping="10" friction="10"/>
    </joint>

    <joint name="joint4" type="revolute">
        <origin xyz="0.0 0.0 ${elbow_length}" rpy="0.0 0.0 0.0"/>
        <parent link="elbow_link"/>
        <child link="forearm_link"/>
        <axis xyz="0.0 0.0 1"/>
        <limit lower="-3.14" upper="3.14" effort="1000.0" velocity="1.0"/>
        <dynamics damping="10" friction="10"/>
    </joint>

    <joint name="joint5" type="revolute">
        <origin xyz="0.0 0.0 ${forearm_length}" rpy="0.0 0.0 0.0"/>
        <parent link="forearm_link"/>
        <child link="wrist_link"/>
        <axis xyz="0.0 1.0 0"/>
        <limit lower="-1.57" upper="1.57" effort="1000.0" velocity="1.0"/>
        <dynamics damping="10" friction="2.0"/>
    </joint>

    <joint name="joint6" type="continuous">
        <origin xyz="0.0 0.0 ${wrist_height}" rpy="0.0 0.0 0.0"/>
        <parent link="wrist_link"/>
        <child link="hand_link"/>
        <axis xyz="0.0 0.0 1.0"/>
        <dynamics damping="0.05" friction="0.1"/>
    </joint>

    <joint name="hand_tool_joint" type="fixed">
        <origin xyz="0.0 0.0 ${hand_height}" rpy="0.0 0.0 0.0"/>
        <parent link="hand_link"/>
        <child link="tool_link"/>
        <dynamics damping="0.05" friction="0.1"/>
    </joint>

    <!-- add gripper relative to hand begin-->
    <xacro:include filename="gripper.xacro" />
    <!-- add gripper relative to hand end-->

</robot>